<div class="max-w-md mx-auto mt-6 sm:mt-10">
  <div class="flex justify-center mb-6">
    <div class="crossy-devise-logo">
      <%= image_tag "crossy_logo.svg", alt: "Crossy", class: "h-20 w-20 sm:h-24 sm:w-24" %>
    </div>
  </div>
  <div class="crossy-card">
    <h1 class="font-display text-2xl font-semibold text-stone-900 mb-1">Create account</h1>
    <p class="text-sm text-stone-600 mb-6">One account for all your networks.</p>

    <%= form_for(resource, as: resource_name, url: user_registration_path) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "crossy-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "crossy-input" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "crossy-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "crossy-input" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, class: "crossy-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "crossy-input" %>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <%= f.submit "Sign up", class: "crossy-btn-primary border-0 cursor-pointer" %>
        <%= link_to "Back to sign in", new_session_path(resource_name), class: "crossy-link text-sm text-center sm:text-right" %>
      </div>
    <% end %>
  </div>
</div>
