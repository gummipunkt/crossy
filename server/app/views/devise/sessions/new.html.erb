<div class="max-w-md mx-auto mt-6 sm:mt-10">
  <div class="flex justify-center mb-6">
    <div class="crossy-devise-logo">
      <%= image_tag "crossy_logo.svg", alt: "Crossy", class: "h-20 w-20 sm:h-24 sm:w-24" %>
    </div>
  </div>
  <div class="crossy-card">
    <h1 class="font-display text-2xl font-semibold text-stone-900 mb-1">Sign in</h1>
    <p class="text-sm text-stone-600 mb-6">Welcome back — pick up where you left off.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "crossy-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "crossy-input" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "crossy-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "crossy-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-5 flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-violet-200 text-violet-600 focus:ring-violet-400" %>
          <%= f.label :remember_me, class: "text-sm text-stone-700" %>
        </div>
      <% end %>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <%= f.submit "Sign in", class: "crossy-btn-primary border-0 cursor-pointer" %>
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm justify-center sm:justify-end">
          <% if devise_mapping.recoverable? %>
            <%= link_to "Forgot password?", new_password_path(resource_name), class: "crossy-link" %>
          <% end %>
          <% if devise_mapping.registerable? %>
            <%= link_to "Create account", new_user_registration_path, class: "crossy-link" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
