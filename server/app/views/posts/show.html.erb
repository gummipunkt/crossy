<div class="mb-6">
  <h1 class="crossy-page-title">Post #<%= @post.id %></h1>
</div>
<div class="crossy-card crossy-card-appear">
  <p class="mb-2 text-stone-800 whitespace-pre-line"><%= @post.content_text %></p>
  <% if @post.content_warning.present? %>
    <p class="mt-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-950"><span class="font-semibold">CW:</span> <%= @post.content_warning %></p>
  <% end %>
</div>

<h2 class="font-display mt-8 text-xl font-semibold text-stone-900">Deliveries</h2>
<turbo-frame id="<%= dom_id(@post, :deliveries) %>" src="<%= deliveries_post_path(@post) %>" data-deliveries-frame="true" loading="lazy">
  <%= render partial: "deliveries", locals: { post: @post, deliveries: @deliveries } %>
</turbo-frame>

<p class="mt-8"><%= link_to "New post", new_post_path, class: "crossy-btn-secondary" %></p>

<% if (pa = @deliveries.find { |d| d.provider_account.provider == "nostr" }&.provider_account) %>
  <h2 class="font-display mt-8 text-xl font-semibold text-stone-900">Nostr</h2>
  <div class="crossy-card mt-3">
    <div class="flex flex-wrap gap-2">
      <button type="button" onclick="window.NostrConnect.connect()" class="crossy-btn-secondary">
        Connect Nostr
      </button>
      <button type="button" onclick="window.NostrConnect.signAndPublish(<%= @post.id %>, <%= pa.id %>)" class="crossy-btn-primary border-0">
        Sign & publish (NIP‑07)
      </button>
      <button type="button" onclick="window.NostrPrepare.prepare(<%= @post.id %>, <%= pa.id %>)" class="crossy-btn-secondary">
        Download event JSON
      </button>
    </div>
  </div>
<% end %>
