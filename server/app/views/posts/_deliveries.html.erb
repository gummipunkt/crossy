<div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-4">
  <% deliveries.each do |d| %>
    <% status_class = case d.status.to_s
      when "succeeded" then "border-green-200/90 bg-green-50/80"
      when "failed" then "border-rose-200/90 bg-rose-50/80"
      when "awaiting_signature" then "border-amber-200/90 bg-amber-50/80"
      else "border-violet-100/80 bg-violet-50/70"
      end %>
    <div class="crossy-card-muted <%= status_class %>">
      <div class="text-sm font-semibold capitalize text-stone-800 mb-1 flex items-center justify-between gap-2">
        <span><%= d.provider_account.provider %></span>
        <span class="inline-flex items-center rounded-full border border-white/60 bg-white/80 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-stone-600">
          <%= d.status %>
        </span>
      </div>
      <% if d.provider_post_id.present? %>
        <div class="text-xs text-stone-600 break-all mt-1 font-mono">ID: <%= d.provider_post_id %></div>
      <% end %>
      <% if d.error_message.present? %>
        <div class="text-xs text-rose-900 mt-3 rounded-md bg-rose-50 px-2 py-1.5 border border-rose-100">Error: <%= d.error_message %></div>
      <% end %>
    </div>
  <% end %>
</div>

