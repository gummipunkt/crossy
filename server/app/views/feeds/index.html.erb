<div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <h1 class="crossy-page-title">Timeline</h1>
    <p class="mt-1 text-sm text-stone-600">All connected feeds in one place</p>
  </div>
  <button type="button" onclick="location.reload()" class="crossy-btn-secondary shrink-0 self-start sm:self-auto">
    <svg class="h-4 w-4 mr-1.5 opacity-60" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.5 8a5.5 5.5 0 0 1 9.3-4M13.5 8a5.5 5.5 0 0 1-9.3 4"/><path d="M11 1.5V4.5H14" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 14.5V11.5H2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Refresh
  </button>
</div>

<script>
  window.__timelineInterval && clearInterval(window.__timelineInterval);
  window.__timelineInterval = setInterval(function(){ location.reload() }, 30000);
  document.addEventListener('turbo:before-render', function(){
    window.__timelineInterval && clearInterval(window.__timelineInterval);
    window.__timelineInterval = null;
  });
</script>

<% if @items.blank? %>
  <div class="crossy-empty-state">
    <svg class="mx-auto mb-4 h-12 w-12 text-violet-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"/><path d="M8 12h.01M16 12h.01M12 12h.01" stroke-linecap="round"/></svg>
    <p class="text-lg font-medium text-stone-700">No posts yet</p>
    <p class="mt-1 text-sm">Connect your accounts under <a href="<%= provider_accounts_path %>" class="crossy-link">Networks</a> to see your feeds here.</p>
  </div>
<% else %>
  <div class="space-y-4">
    <% @items.each do |it| %>
      <article class="crossy-card group">
        <%# Header row: avatar + author + provider badge + timestamp %>
        <div class="flex items-start gap-3">
          <% if it.avatar_url.present? %>
            <img src="<%= it.avatar_url %>" alt="" class="crossy-avatar" loading="lazy"/>
          <% else %>
            <span class="crossy-avatar flex items-center justify-center bg-gradient-to-br from-violet-200 to-purple-200 text-violet-700 text-sm font-bold">
              <%= it.author.to_s[0]&.upcase || "?" %>
            </span>
          <% end %>

          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 flex-wrap">
              <% if it.author.present? %>
                <span class="text-sm font-semibold text-stone-800 truncate max-w-[200px] sm:max-w-none"><%= it.author %></span>
              <% end %>
              <span class="uppercase text-[10px] font-bold tracking-wider px-2 py-0.5 rounded-full border
                <%= case it.provider
                    when "mastodon" then "border-green-200/90 bg-green-100/80 text-green-800"
                    when "bluesky" then "border-sky-200/90 bg-sky-100/80 text-sky-800"
                    when "threads" then "border-amber-200/90 bg-amber-100/80 text-amber-800"
                    when "nostr" then "border-pink-200/90 bg-pink-100/80 text-pink-800"
                    else "border-violet-200/90 bg-violet-100/70 text-violet-800" end %>">
                <%= it.provider %>
              </span>
            </div>
            <span class="text-xs text-stone-500 mt-0.5 block">
              <% if it.url.present? %>
                <a href="<%= it.url %>" target="_blank" rel="noopener" class="hover:text-violet-700 transition-colors"><%= time_ago_in_words(it.created_at) if it.created_at %> ago</a>
              <% else %>
                <%= time_ago_in_words(it.created_at) if it.created_at %> ago
              <% end %>
            </span>
          </div>
        </div>

        <%# Content %>
        <div class="mt-3 whitespace-pre-line text-[15px] leading-relaxed text-stone-800 break-words pl-[52px]"><%= it.content %></div>

        <%# Images %>
        <% if it.images.present? %>
          <div class="mt-3 pl-[52px] grid gap-2 <%= it.images.size == 1 ? 'grid-cols-1' : 'grid-cols-2' %>">
            <% it.images.first(4).each do |im| %>
              <div class="aspect-video overflow-hidden rounded-xl border border-stone-200/80 shadow-inner">
                <img src="<%= im["url"] %>" alt="<%= im["alt"] %>" class="w-full h-full object-cover" loading="lazy"/>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Action bar %>
        <div class="mt-3 pl-[52px] flex flex-wrap items-center gap-1 border-t border-stone-100 pt-3">
          <%# Like %>
          <button type="button"
            class="crossy-action-btn crossy-action-btn--like <%= 'crossy-action-btn--active' if it.liked_by_me %>"
            data-provider="<%= it.provider %>"
            data-id="<%= it.id %>"
            <% if it.cid.present? %>data-cid="<%= it.cid %>"<% end %>
            data-action-type="like"
            onclick="feedAct(this)">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="<%= it.liked_by_me ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.5">
              <path d="M3.172 5.172a4 4 0 0 1 5.656 0L10 6.343l1.172-1.171a4 4 0 1 1 5.656 5.656L10 17.657l-6.828-6.829a4 4 0 0 1 0-5.656Z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <% if it.likes_count.to_i > 0 %><span class="crossy-stat"><%= it.likes_count %></span><% end %>
          </button>

          <%# Repost %>
          <button type="button"
            class="crossy-action-btn crossy-action-btn--repost <%= 'crossy-action-btn--active' if it.reposted_by_me %>"
            data-provider="<%= it.provider %>"
            data-id="<%= it.id %>"
            <% if it.cid.present? %>data-cid="<%= it.cid %>"<% end %>
            data-action-type="repost"
            onclick="feedAct(this)">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 3l-4 4 4 4"/><path d="M3 7h14a2 2 0 0 1 2 2v1"/>
              <path d="M13 17l4-4-4-4"/><path d="M17 13H3a2 2 0 0 1-2-2v-1"/>
            </svg>
            <% if it.reposts_count.to_i > 0 %><span class="crossy-stat"><%= it.reposts_count %></span><% end %>
          </button>

          <%# Bookmark (Mastodon only) %>
          <% if it.provider == "mastodon" %>
            <button type="button"
              class="crossy-action-btn crossy-action-btn--bookmark <%= 'crossy-action-btn--active' if it.bookmarked_by_me %>"
              data-provider="<%= it.provider %>"
              data-id="<%= it.id %>"
              data-action-type="bookmark"
              onclick="feedAct(this)">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="<%= it.bookmarked_by_me ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.5">
                <path d="M5 3a2 2 0 0 0-2 2v12l7-4 7 4V5a2 2 0 0 0-2-2H5Z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          <% end %>

          <%# Replies count %>
          <% if it.replies_count.to_i > 0 %>
            <span class="crossy-action-btn cursor-default" title="Replies">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13a3 3 0 0 1-3 3H7l-4 3V5a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v8Z"/>
              </svg>
              <span class="crossy-stat"><%= it.replies_count %></span>
            </span>
          <% end %>

          <% if it.url.present? %>
            <a href="<%= it.url %>" target="_blank" rel="noopener" class="crossy-action-btn ml-auto">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 3h6v6M17 3 9 11M14 11v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h5"/>
              </svg>
              <span class="hidden sm:inline">Open</span>
            </a>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
<% end %>
