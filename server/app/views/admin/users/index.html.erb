<div class="mb-6">
  <h1 class="crossy-page-title">Users</h1>
  <p class="mt-1 text-sm text-stone-600">Manage accounts and admin roles.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <% @users.each do |u| %>
    <div class="crossy-card">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <div class="text-sm font-semibold">
            <%= link_to u.email, admin_user_path(u), class: "crossy-link break-all" %>
          </div>
          <div class="text-xs text-stone-500 mt-2 flex flex-wrap items-center gap-x-3 gap-y-1">
            <span>Networks: <%= u.read_attribute(:networks_count) %></span>
            <span class="text-stone-300 hidden sm:inline">·</span>
            <span><%= u.admin? ? "Admin" : "User" %></span>
          </div>
        </div>
        <div class="text-right flex flex-col gap-2 shrink-0 items-end">
          <% unless u.admin? %>
            <%= button_to "Make admin", make_admin_admin_user_path(u), method: :post, class: "text-xs font-medium text-violet-700 hover:text-violet-900 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
          <% end %>
          <% if u != current_user %>
            <%= button_to "Delete", admin_user_path(u), method: :delete, data: { confirm: "Delete this user?" }, class: "text-xs font-medium text-red-700 hover:text-red-900 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
