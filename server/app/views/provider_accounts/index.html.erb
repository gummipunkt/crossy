<div class="mb-6">
  <h1 class="crossy-page-title">Networks</h1>
  <p class="mt-1 text-sm text-stone-600">Connect Mastodon, Bluesky, Threads, or Nostr — then pick them in the composer.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
  <% @provider_accounts.each do |pa| %>
    <div class="crossy-card">
      <div class="text-xs font-bold uppercase tracking-wide text-stone-500 mb-1"><%= pa.provider %></div>
      <div class="text-sm font-semibold text-stone-900 break-all"><%= pa.handle %></div>
      <% if (info = (pa.instance || pa.public_key)).present? %>
        <div class="text-xs text-stone-500 mt-2 break-all font-mono leading-relaxed"><%= info %></div>
      <% end %>
      <div class="mt-4">
        <%= button_to "Remove", provider_account_path(pa), method: :delete, data: { confirm: "Remove this network?" }, class: "rounded-lg bg-red-600 text-white text-sm font-medium px-3 py-2 hover:bg-red-700 transition-colors" %>
      </div>
    </div>
  <% end %>
</div>

<h2 class="font-display text-xl font-semibold text-stone-900 mb-3">Connect a network</h2>

<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  <div class="crossy-card-muted">
    <h3 class="font-display font-semibold text-stone-900 mb-3">Mastodon</h3>
    <%= form_with url: provider_accounts_path, method: :post, html: { class: "space-y-3" } do %>
      <input type="hidden" name="provider" value="mastodon">
      <input class="crossy-input" name="handle" placeholder="@you or handle" autocomplete="off">
      <input class="crossy-input" name="instance" placeholder="https://your.instance" autocomplete="off">
      <input class="crossy-input" name="access_token" placeholder="Access token" autocomplete="off">
      <button type="submit" class="crossy-btn-primary w-full sm:w-auto border-0">Connect</button>
    <% end %>
  </div>

  <div class="crossy-card-muted">
    <h3 class="font-display font-semibold text-stone-900 mb-3">Bluesky</h3>
    <%= form_with url: provider_accounts_path, method: :post, html: { class: "space-y-3" } do %>
      <input type="hidden" name="provider" value="bluesky">
      <input class="crossy-input" name="handle" placeholder="Handle or DID" autocomplete="off">
      <input class="crossy-input" name="instance" placeholder="PDS URL (optional)" autocomplete="off">
      <input class="crossy-input" name="app_password" placeholder="App password" autocomplete="off">
      <button type="submit" class="crossy-btn-primary w-full sm:w-auto border-0">Connect</button>
    <% end %>
  </div>

  <div class="crossy-card-muted">
    <h3 class="font-display font-semibold text-stone-900 mb-3">Threads</h3>
    <p class="text-sm text-stone-600 mb-3">OAuth with Meta — you will be redirected to Threads.</p>
    <%= link_to "Connect Threads", "/auth/threads", class: "crossy-btn-primary", data: { turbo: false } %>
  </div>

  <div class="crossy-card-muted">
    <h3 class="font-display font-semibold text-stone-900 mb-3">Nostr</h3>
    <%= form_with url: provider_accounts_path, method: :post, html: { class: "space-y-3" } do %>
      <input type="hidden" name="provider" value="nostr">
      <input class="crossy-input" name="handle" placeholder="Display name" autocomplete="off">
      <input class="crossy-input font-mono text-sm" name="public_key" placeholder="Public key (hex)" autocomplete="off">
      <button type="submit" class="crossy-btn-primary w-full sm:w-auto border-0">Connect</button>
    <% end %>
  </div>
</div>
